# --- Plant identification (Claude Vision API) ---
# Server-side only. Used by app/api/identify+api.ts.
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# --- Firebase (Auth + Firestore) ---
# Create a Firebase project at https://console.firebase.google.com/
# Project settings -> General -> "Your apps" -> Web app config.
# These values are bundled into the client app (safe to expose,
# protect data with Firestore Security Rules instead).
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# --- Build variant ---
# `development` -> bundle id app.verdor.customer.dev, app name "Verdor (Dev)"
# `production`  -> bundle id app.verdor.customer
# EAS sets this automatically per build profile (see eas.json).
APP_VARIANT=development
