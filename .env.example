# --- Plant identification (Claude Vision API) ---
# Server-side only. Used by app/api/identify+api.ts.
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# --- Firebase (Auth + Firestore) ---
# Create a Firebase project at https://console.firebase.google.com/
# Project settings -> General -> "Your apps" -> Web app config.
# These values are bundled into the client app (safe to expose,
# protect data with Firestore Security Rules instead).
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# --- Build variant ---
# `development` -> bundle id app.verdor.customer.dev, app name "Verdor (Dev)"
# `production`  -> bundle id app.verdor.customer
# EAS sets this automatically per build profile (see eas.json).
APP_VARIANT=development

# --- Catalog seed (one-time, dev only) ---
# Used by `npm run seed:catalog` to push src/data/plants.ts into Firestore.
# The signed-in user must have role 'super_admin' or 'tenant_admin' / 'staff_vivero'
# of the target tenant — flip the role in Firebase Console once, then revert if you want.
# SEED_TENANT_ID defaults to 'zamorano' if unset.
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_TENANT_ID=zamorano
