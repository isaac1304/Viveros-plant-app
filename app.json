{
  "expo": {
    "name": "Zamorano",
    "slug": "zamorano-plant-app",
    "scheme": "zamorano",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF7F2"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "cr.zamorano.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Zamorano usa la cámara para identificar plantas y escanear códigos QR.",
        "NSPhotoLibraryUsageDescription": "Zamorano accede a tus fotos para identificar plantas guardadas en la galería."
      }
    },
    "android": {
      "package": "cr.zamorano.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#3DA35D"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "server"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Zamorano usa la cámara para identificar plantas y escanear códigos QR."
        }
      ],
      "expo-font"
    ],
    "extra": {
      "router": {}
    }
  }
}
